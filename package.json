{
  "name": "ai-starred",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-public-data": "tsx scripts/sync-public-data.ts",
    "dev": "npm run sync-public-data && vite",
    "dev:clean": "rm -rf node_modules/.vite && npm run sync-public-data && vite",
    "build": "npm run sync-public-data && vite build",
    "preview": "vite preview",
    "fetch": "tsx scripts/fetch.ts",
    "score": "tsx scripts/score.ts",
    "publish": "tsx scripts/publish.ts",
    "pipeline": "tsx scripts/pipeline.ts",
    "setup-dns": "node scripts/setup-aistarred-dns.mjs",
    "generate-icons": "bash scripts/generate-icons.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
